{
  "name": "@blinkorb/eslint-config",
  "version": "0.3.7",
  "publishConfig": {
    "access": "public"
  },
  "description": "A collection of BlinkOrb's ESLint configs",
  "exports": {
    "./base": "./src/base.ts",
    "./react": "./src/react.ts",
    "./expo": "./src/expo.ts",
    "./jest": "./src/jest.ts",
    "./typeorm": "./src/typeorm.ts",
    "./import-extensions": "./src/import-extensions.ts",
    "./node-import-prefix": "./src/node-import-prefix.ts",
    "./tailwind": "./src/tailwind.ts",
    "./next": "./src/next.ts"
  },
  "scripts": {
    "lint-check": "eslint . --ignore-pattern='test-files/**/*-fail.{ts,tsx,js,jsx}'",
    "lint-fix": "npm run lint-check -- --fix",
    "format-check": "prettier --check .",
    "format-fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "lint-fail": "./scripts/lint-fail.sh",
    "check-exports": "tsx ./scripts/check-exports.ts",
    "test": "npm run format-check && npm run type-check && npm run lint-check && npm run lint-fail && npm run check-exports",
    "inspect": "eslint-config-inspector"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blinkorb/eslint-config.git"
  },
  "keywords": [
    "blinkorb",
    "eslint",
    "config",
    "react",
    "expo"
  ],
  "author": "BlinkOrb Ltd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blinkorb/eslint-config/issues"
  },
  "homepage": "https://github.com/blinkorb/eslint-config#readme",
  "dependencies": {
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/estree": "^1.0.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.7.0",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^3.1.0",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "tsx": "^4.23.1"
  }
}
