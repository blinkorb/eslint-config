{
  "name": "@blinkorb/eslint-config",
  "version": "0.3.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "A collection of BlinkOrb's ESLint configs",
  "exports": {
    "./base": "./src/base.ts",
    "./react": "./src/react.ts",
    "./expo": "./src/expo.ts",
    "./jest": "./src/jest.ts"
  },
  "scripts": {
    "lint-check": "eslint . --ignore-pattern='test-files/**/*-fail.ts'",
    "lint-fix": "npm run lint-check -- --fix",
    "format-check": "prettier --check .",
    "format-fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "lint-fail": "./scripts/lint-fail.sh",
    "test": "npm run format-check && npm run type-check && npm run lint-check && npm run lint-fail",
    "inspect": "eslint --inspect-config"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blinkorb/eslint-config.git"
  },
  "keywords": [
    "blinkorb",
    "eslint",
    "config",
    "react",
    "expo"
  ],
  "author": "BlinkOrb Ltd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blinkorb/eslint-config/issues"
  },
  "homepage": "https://github.com/blinkorb/eslint-config#readme",
  "dependencies": {
    "@types/estree": "^1.0.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^3.0.4",
    "@types/node": "^22.20.1",
    "react": "^19.2.7"
  }
}
